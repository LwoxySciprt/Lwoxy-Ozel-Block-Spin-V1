-- TIKLANMA
--═══════════════════════════════════════════════════════════════
local function InRect(mx,my,rx,ry,rw,rh)
    return mx>=rx and mx<=rx+rw and my>=ry and my<=ry+rh
end

local function Click(mx,my)
    if not MenuOn then return end
    for _, b in pairs(BTN) do
        if b.type == "slider" then
            if InRect(mx,my, b.mA.x,b.mA.y,b.mA.w,b.mA.h) then pcall(b.mA.fn) return end
            if InRect(mx,my, b.pA.x,b.pA.y,b.pA.w,b.pA.h) then pcall(b.pA.fn) return end
        elseif b.type == "toggle" then
            if InRect(mx,my, b.x,b.y,b.w,b.h) then pcall(b.fn) return end
        end
    end
end

