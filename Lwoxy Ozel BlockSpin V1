local PX, PY, PW = 14, 170, 235

local function DR(x,y,w,h,c,f,z)
    local r = Drawing.new("Square")
    r.Position = Vector2.new(x,y); r.Size = Vector2.new(w,h)
    r.Color = c; r.Filled = f; r.Visible = true; r.ZIndex = z or 50
    if not f then r.Thickness = 1 end
    return r
end

local function DT(x,y,t,s,c,z)
    local d = Drawing.new("Text")
    d.Position = Vector2.new(x,y); d.Text = t or ""
    d.Size = s or 13; d.Font = Drawing.Fonts.Plex
    d.Color = c or Color3.fromRGB(210,210,225)
    d.Outline = true; d.OutlineColor = Color3.new(0,0,0)
    d.Visible = true; d.ZIndex = z or 55
    return d
end

local function DL(x1,y1,x2,y2,c,th,z)
    local l = Drawing.new("Line")
    l.From = Vector2.new(x1,y1); l.To = Vector2.new(x2,y2)
    l.Color = c; l.Thickness = th or 1; l.Visible = true; l.ZIndex = z or 52
    return l
end

-- Toggle butonu
local function MkBtn(label, yOff, fn)
    local bx, by, bw, bh = PX+8, PY+yOff, PW-16, 24
    local bg = DR(bx,by,bw,bh, Color3.fromRGB(30,30,42), true, 51)
    bg.Transparency = 0.8
    local box = DR(bx+4, by+4, 16, 16, Color3.fromRGB(60,60,80), false, 56)
    local fill = DR(bx+7, by+7, 10, 10, Color3.fromRGB(80,255,120), true, 57)
    local txt = DT(bx+26, by+4, label, 13, nil, 56)
    local val = DT(bx+bw-40, by+4, "", 13, nil, 56)
    local b = {bg=bg,box=box,fill=fill,txt=txt,val=val, x=bx,y=by,w=bw,h=bh, fn=fn, type="toggle"}
    table.insert(BTN, b)
    return b
end

-- Slider butonu ([-] ve [+])
local function MkSld(label, yOff, fnL, fnR)
    local bx, by, bw, bh = PX+8, PY+yOff, PW-16, 24
    local bg = DR(bx,by,bw,bh, Color3.fromRGB(30,30,42), true, 51)
    bg.Transparency = 0.8
    local mb = DR(bx+4, by+3, 18, 18, Color3.fromRGB(255,80,80), true, 57)
    local mt = DT(bx+9, by+3, "-", 13, Color3.fromRGB(255,255,255), 58)
    local txt = DT(bx+28, by+4, label, 13, nil, 56)
    local val = DT(bx+bw-65, by+4, "", 13, Color3.fromRGB(200,200,255), 56)
    local pb = DR(bx+bw-22, by+3, 18, 18, Color3.fromRGB(80,255,120), true, 57)
    local pt = DT(bx+bw-17, by+3, "+", 13, Color3.fromRGB(0,0,0), 58)
    local s = {
        bg=bg, mb=mb, mt=mt, pb=pb, pt=pt, txt=txt, val=val,
        x=bx, y=by, w=bw, h=bh,
        mA={x=bx+4,y=by+3,w=18,h=18,fn=fnL},
        pA={x=bx+bw-22,y=by+3,w=18,h=18,fn=fnR},
        type="slider"
    }
    table.insert(BTN, s)
    return s
end

