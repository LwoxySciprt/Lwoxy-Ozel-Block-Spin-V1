-- SKELETON ESP
--═══════════════════════════════════════════════════════════════
local function MkESP(p)
    if ESP[p] then return end
    local l = {}
    for i = 1, 14 do
        local d = Drawing.new("Line")
        d.Thickness = CFG.ESP_Th; d.Color = CFG.ESP_Col
        d.Visible = false; d.ZIndex = 5
        l[i] = d
    end
    ESP[p] = l
end

local function RmESP(p)
    if not ESP[p] then return end
    for _, l in pairs(ESP[p]) do pcall(function() l:Remove() end) end
    ESP[p] = nil
end

local function UpESP(p)
    local lines = ESP[p]
    if not lines then return end
    if p == LP or not CFG.ESP or not Alive(p) then
        for _, l in pairs(lines) do l.Visible = false end
        return
    end
    local c = p.Character
    local bones = GetBones(c)
    if not bones then
        for _, l in pairs(lines) do l.Visible = false end
        return
    end
    for i, l in pairs(lines) do
        local b = bones[i]
        if not b then l.Visible = false
        else
            local a = c:FindFirstChild(b[1])
            local bb = c:FindFirstChild(b[2])
            if a and bb then
                local sa, oa = W2S(a.Position)
                local sb, ob = W2S(bb.Position)
                if oa and ob then
                    l.From = sa; l.To = sb
                    l.Color = CFG.ESP_Col; l.Thickness = CFG.ESP_Th
                    l.Visible = true
                else l.Visible = false end
            else l.Visible = false end
        end
    end
end

--═══════════════════════════════════════════════════════════════
-- AIMBOT - CFRAME METHOD (HER EXECUTORDA CALISIR)
-- Sag tik basili tutunca en yakin oyuncunun Head kismina
-- kamera dondirilir. Smooth ile yavas/hizli ayarlanir.
--═══════════════════════════════════════════════════════════════
local function FindClosest()
    local ctr = Ctr()
    local best, bestD = nil, CFG.FOV

    for _, p in pairs(Players:GetPlayers()) do
        if not Valid(p) then continue end

        local head = p.Character and p.Character:FindFirstChild("Head")
        if not head then continue end

        local sp, onScr, z = W2S(head.Position)
        if not onScr or z < 1 then continue end

        local d = (sp - ctr).Magnitude
        if d < bestD then
            bestD = d
            best = p
        end
    end
    return best
end

local function DoAim()
    if not CFG.Aim or not AimHold then
        Target = nil
        return
    end

    -- Kendi karakterimiz var mi kontrol et
    local myChar = LP.Character
    if not myChar then Target = nil return end
    local myHead = myChar:FindFirstChild("Head")
    if not myHead then Target = nil return end

    -- En yakin hedefi bul
    local tgt = FindClosest()
    Target = tgt
    if not tgt then return end

    local tgtChar = tgt.Character
    if not tgtChar then return end
    local tgtHead = tgtChar:FindFirstChild("Head")
    if not tgtHead then return end

    -- Kameranin su anki pozisyonu
    local camPos = Camera.CFrame.Position

    -- Hedefin Head pozisyonu
    local tgtPos = tgtHead.Position

    -- Hedefe dogru CFrame hesapla
    local targetCF = CFrame.lookAt(camPos, tgtPos)

    -- Smooth uygula: 1 = anlik, yuksek = yavas
    -- Lerp ile yumusak gecis
    local alpha = 1 / math.clamp(CFG.Smooth, 1, 50)

    -- Kamerayi hedefe dondur
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, alpha)
end

