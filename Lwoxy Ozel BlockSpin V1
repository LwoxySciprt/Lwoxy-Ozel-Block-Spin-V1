local function Notify(msg, dur)
    dur = dur or 2
    local cx = Camera.ViewportSize.X / 2
    local b = Drawing.new("Square")
    b.Size = Vector2.new(270, 28)
    b.Position = Vector2.new(cx-135, 10)
    b.Color = Color3.fromRGB(18,18,28)
    b.Filled = true; b.Transparency = 0.92; b.Visible = true; b.ZIndex = 300
    local t = Drawing.new("Text")
    t.Text = msg; t.Size = 13; t.Font = Drawing.Fonts.Plex
    t.Color = Color3.fromRGB(200,200,255); t.Center = true
    t.Outline = true; t.OutlineColor = Color3.new(0,0,0)
    t.Position = Vector2.new(cx, 17); t.Visible = true; t.ZIndex = 301
    task.delay(dur, function()
        pcall(function() b:Remove() end)
        pcall(function() t:Remove() end)
    end)
end

