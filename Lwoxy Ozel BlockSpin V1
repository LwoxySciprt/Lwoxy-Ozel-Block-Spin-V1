--═══════════════════════════════════════════════════════════════
-- YARDIMCI
--═══════════════════════════════════════════════════════════════
local function W2S(p)
    local v, o = Camera:WorldToViewportPoint(p)
    return Vector2.new(v.X, v.Y), o, v.Z
end

local function Ctr()
    local s = Camera.ViewportSize
    return Vector2.new(s.X/2, s.Y/2)
end

local function Alive(p)
    if not p or p == LP then return false end
    local c = p.Character
    if not c then return false end
    local h = c:FindFirstChildWhichIsA("Humanoid")
    if not h or h.Health <= 0 then return false end
    if not c:FindFirstChild("HumanoidRootPart") then return false end
    if not c:FindFirstChild("Head") then return false end
    return true
end

local function Valid(p)
    if not Alive(p) then return false end
    for _, n in pairs(CFG.Blacklist) do
        if p.Name == n or p.DisplayName == n then return false end
    end
    if CFG.TeamCheck and p.Team and LP.Team and p.Team == LP.Team then return false end
    return true
end

local function GetBones(c)
    if c:FindFirstChild("UpperTorso") then return R15B end
    if c:FindFirstChild("Torso") then return R6B end
    return nil
end

