local function UpdGUI()
    local g = Color3.fromRGB(80,255,120)
    local r = Color3.fromRGB(255,60,60)

    GUI.bESP.fill.Color = CFG.ESP and g or r
    GUI.bESP.val.Text = CFG.ESP and "ON" or "OFF"
    GUI.bESP.val.Color = CFG.ESP and g or r

    GUI.bAim.fill.Color = CFG.Aim and g or r
    GUI.bAim.val.Text = CFG.Aim and "ON" or "OFF"
    GUI.bAim.val.Color = CFG.Aim and g or r

    GUI.bTeam.fill.Color = CFG.TeamCheck and g or r
    GUI.bTeam.val.Text = CFG.TeamCheck and "ON" or "OFF"
    GUI.bTeam.val.Color = CFG.TeamCheck and g or r

    GUI.sFOV.val.Text = tostring(math.floor(CFG.FOV))
    GUI.sSm.val.Text = tostring(CFG.Smooth)

    if Target and Target.Parent then
        GUI.tgt.Text = "Target: "..Target.Name
        GUI.tgt.Color = Color3.fromRGB(255,200,60)
    else
        GUI.tgt.Text = "Target: ---"
        GUI.tgt.Color = Color3.fromRGB(110,110,135)
    end

    if #CFG.Blacklist > 0 then
        local s = table.concat(CFG.Blacklist, ", ")
        if #s > 28 then s = s:sub(1,28).."..." end
        GUI.bl.Text = "Blacklist: "..s
    else
        GUI.bl.Text = "Blacklist: (bos)"
    end
end

local function ShowGUI(v)
    for _, o in pairs(GUI) do
        if typeof(o) == "table" and o.bg then
            for _, s in pairs(o) do
                if typeof(s) ~= "function" and typeof(s) ~= "number" and typeof(s) ~= "string" and typeof(s) ~= "table" then
                    pcall(function() s.Visible = v end)
                end
            end
        else
            pcall(function() o.Visible = v end)
        end
    end
end

